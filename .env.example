# SafetyGuard Configuration File
# Скопируйте этот файл в .env и настройте параметры

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ==================== PATHS ====================
UPLOAD_DIR=./uploads
RESULT_DIR=./results

# ==================== MODEL ====================
MODEL_PATH=backend/best.pt
MODEL_QUANTIZED_PATH=backend/best_quantized.onnx

# ==================== PROCESSING ====================
BATCH_SIZE=1
IMG_SIZE=640
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ==================== SECURITY ====================
CORS_ORIGINS=*
ALLOWED_HOSTS=localhost,127.0.0.1
MAX_UPLOAD_SIZE=500MB
